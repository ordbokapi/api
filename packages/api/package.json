{
  "name": "ordbokapi",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "ISC",
  "engines": {
    "node": ">=22.5.1",
    "yarn": ">=4.3.1"
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json && node ./copy-head.mjs",
    "format": "oxfmt --write src/ test/",
    "start": "tsc --build tsconfig.build.json && node dist/main",
    "start:dev": "run-on-tsc-build yarn node dist/main.js",
    "start:debug": "NEST_DEBUG=true yarn start:dev",
    "start:prod": "node dist/main",
    "lint": "oxlint --fix src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "test:extract-fixtures": "node scripts/extract-fixtures.mjs",
    "generate:schema": "node scripts/gen-article-schema.mjs"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/fastify": "^3.1.0",
    "@nestjs/apollo": "^13.4.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.4.0",
    "@nestjs/platform-fastify": "^11.1.19",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.5",
    "graphql": "^17.0.0",
    "lru-cache": "^11.3.5",
    "memjs": "^1.3.2",
    "ordbokapi-common": "workspace:^",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/express": "^5.0.6",
    "@types/memjs": "^1.3.3",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "json-schema-to-typescript": "^15.0.4",
    "meilisearch": "^0.58.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.66.0",
    "pg": "^8.20.0",
    "run-on-tsc-build": "workspace:^",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
