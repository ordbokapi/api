exports[`Norsk Ordbok article > returns definitions with content and examples 1`] = `
{
  "definitions": [
    {
      "content": [
        {
          "textContent": "mjuk, feittrik masse i det indre av dei fleste bein el knoklar",
        },
        {
          "textContent": "òg i sms som beinmerg, ryggmerg",
        },
      ],
      "examples": [
        {
          "textContent": "den (for)lengde mergen",
        },
        {
          "textContent": "mange av beini er innhole og fyllte med merg",
        },
      ],
      "id": 3,
      "subDefinitions": [
        {
          "content": [
            {
              "textContent": "det inste, mest kjenslevare hjå menneske",
            },
          ],
          "id": 4,
        },
        {
          "content": [
            {
              "textContent": "gen.",
            },
          ],
          "id": 10,
        },
      ],
    },
    {
      "content": [
        {
          "textContent": "indre del av visse organ, t skiln frå den ytre delen",
        },
        {
          "textContent": "òg i sms som nyremerg",
        },
      ],
      "examples": [],
      "id": 7,
      "subDefinitions": [],
    },
    {
      "content": [
        {
          "textContent": "indre, laust bygt vev i røter og stenglar",
        },
      ],
      "examples": [
        {
          "textContent": "hos til dømes eik lagar mergen ei femspissa stjerne",
        },
      ],
      "id": 11,
      "subDefinitions": [],
    },
    {
      "content": [],
      "examples": [],
      "id": 12,
      "subDefinitions": [
        {
          "content": [
            {
              "textContent": "kjerne i korn",
            },
          ],
          "id": 6,
        },
        {
          "content": [
            {
              "textContent": "kjerne i nøtt",
            },
          ],
          "id": 9,
        },
      ],
    },
    {
      "content": [
        {
          "textContent": "midtre del av (tjukt) tauverk",
